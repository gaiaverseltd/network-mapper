# Accel Net – copy to .env and fill in values
# Get Firebase config from: Project settings → General → Your apps

# Optional: set to true or 1 to hide signup page and show login at /
# VITE_HIDE_SIGNUP=

# Firebase (required)
VITE_ApiKey=
VITE_AuthDomain=
VITE_StorageBucket=
VITE_MessagingSenderId=
VITE_AppId=1:XXXXXXXXXX:web
VITE_MeasurementId=G-XXXXXXXXXX

# Email: Cloud Function uses Inboxroad API (configure in Firebase, not .env)
# firebase functions:config:set inboxroad.token="YOUR_API_TOKEN" inboxroad.from_email="noreply@yourdomain.com" inboxroad.from_name="Accel Net"
# Get token: https://www.inboxroad.com/obtain-api-token

# Cloud Function URL (after deploy) – for notification emails
# VITE_CloudFunction_EmailUrl=https://REGION-PROJECT.cloudfunctions.net/sendNotificationEmail

# Search analytics – record search requests (Cloud Function recordSearch)
# VITE_SearchAnalyticsUrl=https://REGION-PROJECT.cloudfunctions.net/recordSearch

# AI filter suggestion (Cloud Functions): set GOOGLE_GENAI_API_KEY in Firebase params for suggestSearchFilters
# e.g. firebase functions:config:set GOOGLE_GENAI_API_KEY="YOUR_GEMINI_API_KEY" or use functions/.env
